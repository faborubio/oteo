<li class="flex gap-3 text-sm border-l-2 border-gray-200 pl-3 py-1">
  <div class="text-gray-400 whitespace-nowrap text-xs pt-0.5"><%= l(event.occurred_at, format: :short) %></div>
  <div>
    <span class="font-medium text-gray-700"><%= event.event_type.humanize %></span>
    <% if event.product.present? %>
      <span class="text-xs bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded ml-1"><%= event.product.upcase %></span>
    <% end %>
    <% if event.body.present? %>
      <p class="text-gray-600"><%= event.body %></p>
    <% end %>
  </div>
</li>
