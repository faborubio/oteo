<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Oteo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Oteo">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Tailwind build (app/assets/builds/tailwind.css) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 text-gray-900">
    <% if authenticated? %>
      <nav class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
          <div class="flex items-center gap-6">
            <%= link_to "Oteo", root_path, class: "font-bold text-lg text-emerald-700" %>
            <%= link_to "Leads", businesses_path, class: nav_link_class(controller_name == "businesses" && action_name != "map") %>
            <%= link_to "Mapa", map_businesses_path, class: nav_link_class(action_name == "map") %>
            <%= link_to "Kanban", kanban_path, class: nav_link_class(controller_name == "kanban") %>
            <%= link_to "Salud", health_path, class: nav_link_class(controller_name == "health") %>
          </div>
          <%= button_to "Salir", session_path, method: :delete,
                class: "text-sm text-gray-500 hover:text-gray-800" %>
        </div>
      </nav>
    <% end %>

    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="rounded-md bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-2 text-sm"><%= notice %></div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
