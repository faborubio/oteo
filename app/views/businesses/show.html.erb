<% content_for :title, "#{@business.name} — Oteo" %>

<%= link_to "← Volver a leads", businesses_path, class: "text-sm text-gray-500 hover:text-gray-800" %>

<div class="mt-3 grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# --- Columna principal --- %>
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-2xl font-bold"><%= @business.name %></h1>
          <p class="text-gray-500"><%= @business.address %> · <%= @business.comuna.name %></p>
        </div>
        <%= presence_badge(@business.digital_presence) %>
      </div>

      <div class="mt-4 flex flex-wrap gap-4 text-sm">
        <% if @business.phone.present? %>
          <%= link_to "📞 #{@business.phone}", "tel:#{@business.phone}", class: "text-emerald-700 font-medium" %>
        <% end %>
        <% if (site_url = safe_external_url(@business.website_uri)) %>
          <%= link_to "🌐 Sitio", site_url, target: "_blank", rel: "noopener", class: "text-emerald-700 font-medium" %>
        <% end %>
        <% if @business.lat && @business.lng %>
          <%= link_to "📍 Cómo llegar", "https://www.google.com/maps/search/?api=1&query=#{@business.lat},#{@business.lng}",
                target: "_blank", rel: "noopener", class: "text-emerald-700 font-medium" %>
        <% end %>
      </div>

      <% if @business.rubros.any? %>
        <div class="mt-3 flex flex-wrap gap-1">
          <% @business.rubros.each do |rubro| %>
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded"><%= rubro.label %></span>
          <% end %>
        </div>
      <% end %>

      <% if @business.status_closed_temporarily? %>
        <p class="mt-3 text-sm text-yellow-700 bg-yellow-50 border border-yellow-200 rounded px-3 py-2">
          ⚠️ Google lo marca como cerrado temporalmente — excluir de rutas de visita.
        </p>
      <% end %>
    </div>

    <%# Guion de venta según estado de presencia (ADR-003) %>
    <% if sales_script(@business.digital_presence) %>
      <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-5">
        <h2 class="text-sm font-semibold text-emerald-900 uppercase tracking-wide mb-1">Ángulo de venta</h2>
        <p class="text-sm text-emerald-900"><%= sales_script(@business.digital_presence) %></p>
      </div>
    <% end %>

    <%# Historial de contacto (append-only) %>
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Historial</h2>

      <%= render "contact_events/form", business: @business, contact_event: @contact_event %>

      <ul id="contact_events" class="mt-4 space-y-2">
        <%= render partial: "contact_events/event", collection: @contact_events, as: :event %>
      </ul>
    </div>
  </div>

  <%# --- Barra lateral --- %>
  <div class="space-y-6">
    <div class="bg-white rounded-lg border border-gray-200 p-5 text-center">
      <div class="text-xs text-gray-500 uppercase tracking-wide">Lead score</div>
      <div class="text-4xl font-bold text-emerald-700 tabular-nums"><%= lead_score_display(@business.lead_score) %></div>
      <div class="text-sm text-gray-500 mt-1"><%= @business.user_rating_count %> reseñas · ⭐ <%= @business.rating || "—" %></div>
    </div>

    <%= render "pos_panel", business: @business %>
  </div>
</div>
